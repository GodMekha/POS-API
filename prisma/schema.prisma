// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  user_id     String   @id @default(uuid()) @db.VarChar(36)
  username    String
  password    String
  phoneNumber Int
  profile     String?
  role        String   @default("general")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  order_id   String        @id @default(uuid()) @db.VarChar(34)
  userId     String        @db.VarChar(34)
  users      User          @relation(fields: [userId], references: [user_id])
  totalPrice Int
  currency   String
  status     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  details    OrderDetail[]
}

model OrderDetail {
  ordrd_id  String   @id @default(uuid()) @db.VarChar(34)
  orderId   String   @db.VarChar(34)
  order     Order    @relation(fields: [orderId], references: [order_id])
  productId String
  amount    Int
  total     Int
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  category_id String    @id @default(uuid()) @db.VarChar(34)
  name        String
  icon        String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  product_id        String             @id @default(uuid()) @db.VarChar(34)
  categoryId        String             @db.VarChar(34)
  category          Category           @relation(fields: [categoryId], references: [category_id])
  image             String
  productName       String
  productDetail     String?
  productQty        Int
  productPrice      Int
  barcode           String?            @unique
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  historyInProducts HistoryInProduct[]
}

model HistoryInProduct {
  hip_id        String   @id @default(uuid()) @db.VarChar(34)
  productId     String   @db.VarChar(34)
  products      Product  @relation(fields: [productId], references: [product_id])
  productName   String
  productDetail String?
  productQty    Int
  productPrice  Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Inventory {
  inventory_id String               @id @default(uuid()) @db.VarChar(34)
  list         String
  unit         String
  amount       Int
  price        Int
  totalPrice   Int
  status       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  histories    HistoryInInventory[]
}

model HistoryInInventory {
  id          String    @id @default(uuid()) @db.VarChar(34)
  inventoryId String    @db.VarChar(34)
  inventory   Inventory @relation(fields: [inventoryId], references: [inventory_id])
  list        String
  unit        String
  amount      Int
  price       Int
  totalPrice  Int
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Supply {
  supply_id String     @id @default(uuid()) @db.VarChar(34)
  company   String
  phone     Int
  sellName  String
  position  String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]
}

model Purchase {
  purchase_id  String           @id @default(uuid()) @db.VarChar(34)
  supplyId     String           @db.VarChar(34)
  supply       Supply           @relation(fields: [supplyId], references: [supply_id])
  currency     String
  expressName  String?
  expressPrice Int
  totalPrice   Int
  status       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  details      PurchaseDetail[]
}

model PurchaseDetail {
  pd_id      String   @id @default(uuid()) @db.VarChar(34)
  purchaseId String   @db.VarChar(34)
  purchase   Purchase @relation(fields: [purchaseId], references: [purchase_id])
  list       String
  unit       String
  amount     Int
  price      Int
  total      Int
  status     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Package {
  id        String   @id @default(uuid()) @db.VarChar(34)
  name      String
  timeline  String
  price     Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sells     Sell[]
}

model Customer {
  id        String   @id @default(uuid()) @db.VarChar(34)
  fullname  String
  phone     Int
  address   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sells     Sell[]
}

model Sell {
  id          String       @id @default(uuid()) @db.VarChar(34)
  customerId  String       @db.VarChar(34)
  customer    Customer     @relation(fields: [customerId], references: [id])
  packageId   String       @db.VarChar(34)
  package     Package      @relation(fields: [packageId], references: [id])
  discount    Float
  totalPrice  Int
  status      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  sellDetails SellDetail[]
}

model SellDetail {
  id        String   @id @default(uuid()) @db.VarChar(34)
  sellId    String   @db.VarChar(34)
  sell      Sell     @relation(fields: [sellId], references: [id])
  partId    String   @db.VarChar(34)
  part      Part     @relation(fields: [partId], references: [id])
  amount    Int
  total     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Part {
  id          String       @id @default(uuid()) @db.VarChar(34)
  list        String
  amount      Int
  price       Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  sellDetails SellDetail[]
}
